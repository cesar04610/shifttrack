# Puerto del servidor (las 4 computadoras acceden por http://IP_DEL_SERVIDOR:3000)
PORT=3000

# Clave secreta para JWT (cambia esto por una cadena larga y aleatoria)
JWT_SECRET=shifttrack_clave_secreta_muy_larga_cambiar_en_produccion

# Configuracion de email para alertas de ausencia (opcional)
# Si no tienes SMTP, deja estos campos en blanco y las alertas se desactivaran
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion
ADMIN_EMAIL=correo_del_administrador@gmail.com

# Ruta de la base de datos SQLite (archivo local)
DB_PATH=./db/shifttrack.db
